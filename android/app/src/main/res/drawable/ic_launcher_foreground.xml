<?xml version="1.0" encoding="utf-8"?>
<!--
  Premium water drop icon — SipUp
  108×108dp canvas. Safe zone: (21,21)→(87,87).
  Design: mathematically precise teardrop + glass highlight system.

  Layer order (back to front):
    1. Drop body       — crisp white
    2. Left highlight  — wide soft panel, creates glass/liquid depth
    3. Right rim       — subtle edge light, adds 3-D roundness
    4. Specular glint  — bright oval, the "spark" that screams premium
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── 1. Drop body ─────────────────────────────────────────────────
         Bezier-constructed teardrop.
         Top spike : (54, 16)
         Widest    : x ∈ [24, 84]  at  y ≈ 68   (radius = 30)
         Bottom    : (54, 96)
         Four cubic segments give perfectly smooth continuity at every joint.
    ──────────────────────────────────────────────────────────────────── -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="
          M 54,16
          C 74,30  84,50  84,68
          C 84,84  70,96  54,96
          C 38,96  24,84  24,68
          C 24,50  34,30  54,16
          Z" />

    <!-- ── 2. Left highlight panel ───────────────────────────────────────
         Thin crescent on the upper-left interior of the drop.
         Low opacity → wide, soft diffusion = frosted-glass / liquid look.
    ──────────────────────────────────────────────────────────────────── -->
    <path
        android:fillColor="#26FFFFFF"
        android:pathData="
          M 44,34
          C 40,46  35,62  36,72
          C 36,77  40,79  44,77
          C 41,66  40,52  44,40
          C 46,33  47,28  44,34
          Z" />

    <!-- ── 3. Right rim highlight ────────────────────────────────────────
         Very faint sliver on the right interior edge.
         Mimics the secondary bounce light on a sphere → convincing 3-D.
    ──────────────────────────────────────────────────────────────────── -->
    <path
        android:fillColor="#12FFFFFF"
        android:pathData="
          M 66,36
          C 70,46  74,60  73,72
          C 72,78  70,82  68,84
          C 71,78  73,68  71,56
          C 70,46  66,38  66,36
          Z" />

    <!-- ── 4. Specular glint ─────────────────────────────────────────────
         Small bright oval offset to upper-right of center.
         This is the single detail that elevates "flat" to "premium".
         On curved translucent surfaces light concentrates into a tight spot.
    ──────────────────────────────────────────────────────────────────── -->
    <path
        android:fillColor="#CCFFFFFF"
        android:pathData="
          M 58,24
          C 62,24  65,27  65,30
          C 65,33  62,35  58,34
          C 55,33  52,30  53,27
          C 53,24  55,24  58,24
          Z" />

</vector>
