<?xml version="1.0" encoding="utf-8"?>
<!--
  Premium 3-stop diagonal gradient:
  Deep navy → rich blue → vibrant cyan
  Gives a sophisticated "ocean depth" feel
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="135"
        android:startColor="#0D1B6E"
        android:centerColor="#1565C0"
        android:endColor="#0097B2" />
</shape>
